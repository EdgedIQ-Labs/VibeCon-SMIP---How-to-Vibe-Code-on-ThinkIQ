# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

AZURE_OPENAI_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com/
AZURE_OPENAI_API_KEY=<your-key>
AZURE_OPENAI_DEPLOYMENT=gpt-5-chat
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# ---------------------------------------------------------------------------
# Display-script playground (PAGES/05_playground)
# ---------------------------------------------------------------------------
# Root of the instance subtree shown in the left pane. Dot-separated FQN; the
# playground hits /api/tool/get_object_subtree once on mount and folds the
# returned descendants under this root. Defaults to the singleton SMIP system
# node on a fresh tenant. Set to your organization's FQN per project.
PLAYGROUND_ROOT_FQN=thinkiq_system
